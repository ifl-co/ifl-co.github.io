<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Proposta de Domínio</title>
  <style>
    :root{
      --bg:#0b0e14;
      --panel:#151922;
      --panel-2:#252b38ec;
      --border:#2b3140;
      --text:#f3f5f7;
      --muted:#a8b0bd;
      --accent:#fad37f;
      --accent-2:#c4a562;
      --danger:#ff7a7a;
      --shadow:0 10px 30px rgba(0, 0, 0, 0.486);
      --radius:18px;
    }

    *{box-sizing:border-box}

    html,body{
      margin:0;
      padding:0;
      background:#0D0F14;
      color:var(--text);
      font-family:Inter,Segoe UI,Arial,sans-serif;
      min-height:100%;
    }

    body{
      display:flex;
      align-items:center;
      justify-content:center;
      padding:24px;
      padding-top:60px;
    }

    .wrap{
      width:93%;
      max-width:500px;
    }

    .card{
      background:linear-gradient(180deg,var(--panel) 0%, var(--panel-2) 100%);
      border:1px solid var(--border);
      border-radius:var(--radius);
      box-shadow:var(--shadow);
      padding:60px;
    }

    .eyebrow{
      display:inline-block;
      padding:6px 10px;
      border:1px solid rgba(214,179,106,.28);
      background:rgba(214,179,106,.08);
      border-radius:999px;
      color:var(--accent-2);
      font-size:12px;
      letter-spacing:.04em;
      margin-bottom:14px;
    }

    p{
      margin:0 0 18px;
      color:var(--muted);
      line-height:1.55;
      font-size:15px;
    }

    .domain-box{
      margin:0 0 18px;
      padding:14px 16px;
      border-radius:14px;
      background:rgba(255,255,255,.03);
      border:1px solid var(--border);
    }

    .domain-label{
      display:block;
      font-size:12px;
      color:var(--muted);
      margin-bottom:6px;
      text-transform:uppercase;
      letter-spacing:.08em;
    }

    .domain-value{
      font-size:18px;
      font-weight:700;
      word-break:break-word;
    }

    .field{
      margin-bottom:16px;
    }

    label{
      display:block;
      margin-bottom:8px;
      font-size:14px;
      font-weight:600;
    }

    .input-wrap{
      position:relative;
    }

    .currency{
      position:absolute;
      left:14px;
      top:50%;
      transform:translateY(-50%);
      color:var(--muted);
      pointer-events:none;
      font-weight:600;
    }

    input{
      width:100%;
      height:56px;
      border-radius:14px;
      border:1px solid var(--border);
      background:#0f131a;
      color:var(--text);
      padding:0 16px 0 44px;
      font-size:20px;
      font-weight:700;
      outline:none;
      transition:.2s border-color,.2s box-shadow;
    }

    input:focus{
      border-color:rgba(214,179,106,.65);
      box-shadow:0 0 0 4px rgba(214,179,106,.12);
    }

    .error{
      display:none;
      margin-top:10px;
      color:var(--danger);
      font-size:13px;
      line-height:1.45;
    }

    button{
      width:100%;
      height:56px;
      border:none;
      border-radius:14px;
      cursor:pointer;
      background:linear-gradient(180deg,var(--accent-2) 0%, var(--accent) 100%);
      color:#16120a;
      font-size:16px;
      font-weight:800;
      letter-spacing:.01em;
      transition:transform .08s ease, filter .2s ease;
      margin-top:8px;
    }

    button:hover{ filter:brightness(1.04); }
    button:active{ transform:translateY(1px); }

    @media (max-width: 480px){
      body{ padding:14px; }
      .card{ padding:18px; border-radius:16px; }
      input{ font-size:18px; }
      .domain-value{ font-size:16px; }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="card">
      <span class="eyebrow">NEGOCIAÇÃO DE DOMÍNIO</span>
      <p>Se este domínio é de seu interesse e deseja adquiri-lo, faça uma proposta.</p>

      <div class="domain-box">
        <span class="domain-label">Domínio informado</span>
        <div class="domain-value" id="domainValue">—</div>
      </div>

      <div class="field">
        <label for="offer">Valor proposto</label>
        <div class="input-wrap">
          <span class="currency">R$</span>
          <input id="offer" type="text" inputmode="numeric" placeholder="0,00" />
        </div>
        <div class="error" id="errorBox">Informe um valor válido para prosseguir.</div>
      </div>

      <button id="continueBtn">Prosseguir com proposta</button>
    </div>
  </div>

  <script>
    (function () {
      const PHONE = "556131422898";

      const params = new URLSearchParams(window.location.search);
      let rawText = (params.get("text") || "").trim();

      function base64UrlDecode(str) {
        try {
          str = str.replace(/-/g, '+').replace(/_/g, '/');
          str += '='.repeat((4 - str.length % 4) % 4);
          return atob(str);
        } catch {
          return "";
        }
      }

      function sanitize(value) {
        return value.replace(/[<>]/g, "").trim();
      }

      const decoded = sanitize(base64UrlDecode(rawText)) || "este domínio";
      document.getElementById("domainValue").textContent = decoded;

      const input = document.getElementById("offer");
      const error = document.getElementById("errorBox");

      function format(v) {
        v = v.replace(/\D/g, "");
        if (!v) return "";
        return (parseInt(v) / 100).toLocaleString("pt-BR", {
          minimumFractionDigits: 2,
          maximumFractionDigits: 2
        });
      }

      input.addEventListener("input", e => {
        e.target.value = format(e.target.value);
        error.style.display = "none";
      });

      document.getElementById("continueBtn").onclick = () => {
        const digits = input.value.replace(/\D/g, "");
        if (!digits) {
          error.style.display = "block";
          return;
        }

        const value = (parseInt(digits) / 100).toLocaleString("pt-BR", {
          style: "currency",
          currency: "BRL"
        });

        const msg =
          "Olá, tenho interesse no domínio " + decoded + ".\n\n" +
          "*Faço-lhe uma oferta inicial no valor de:* " + value;

        const url =
          "https://api.whatsapp.com/send/?phone=" + PHONE +
          "&text=" + encodeURIComponent(msg);

        window.location.href = url;
      };
    })();
  </script>
</body>
</html>
